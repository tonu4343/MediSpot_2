# Copy this file to .env.test and fill in a DISPOSABLE Supabase project -
# never production. Both npm run test:e2e and npm run test:security load
# this automatically (playwright.config.mjs uses process.loadEnvFile;
# test:security uses --env-file directly).
#
# Set up the test project once with: run every file in supabase/migrations/
# (in order) against it via the Supabase SQL editor, same as production.

# Settings -> API in your test Supabase project's dashboard.
TEST_SUPABASE_URL=https://your-test-project.supabase.co
TEST_SUPABASE_ANON_KEY=

# Settings -> API -> service_role (secret). Enables automatic test-user
# cleanup and the direct-DB assertions used by the RLS/security specs.
# Without it, most specs skip themselves rather than fail.
TEST_SUPABASE_SERVICE_ROLE_KEY=
